// Prisma schema — Postgres data foundation for the Commonplace marketplace.
// Mirrors the `Listing` domain type (src/lib/listing.ts) plus the raw WooCommerce
// fields we import. The client is consumed by src/lib/db.ts and src/lib/dataSource.ts.
//
// Prisma 7 note: the datasource `url` is NO LONGER allowed in the schema (P1012).
// The connection string lives in prisma.config.ts (`datasource.url` <- DATABASE_URL)
// for Migrate/CLI, and is passed to `new PrismaClient({ accelerateUrl })` at runtime.
// See scripts/README-import.md.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  // Emit explicit ".ts" import specifiers inside the generated (—@ts-nocheck) client
  // so BOTH bundlers (Next/Turbopack) AND plain Node ESM — used by
  // scripts/import-listings.mjs via native TypeScript type-stripping — can resolve it.
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

/// A sellable marketplace listing, normalized 1:1 from the WooCommerce Store API.
/// `id` is the WooCommerce product id (stable) so imports upsert idempotently.
model Listing {
  id           Int      @id
  slug         String   @unique
  title        String
  priceCents   Int
  /// Original/retail price when on sale, else null.
  retailCents  Int?
  savingsPct   Int?
  categoryName String
  categorySlug String
  /// Parsed "City, ST" when present in the title.
  location     String?
  condition    String?
  /// string[] of image URLs.
  images       Json
  /// string[] of plain-text description paragraphs.
  description  Json
  sku          String
  dimensions   String?
  weight       String?
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  permalink    String
  updatedAt    DateTime @updatedAt

  @@index([categorySlug])
  @@index([priceCents])
  @@index([rating])
  @@index([updatedAt])
}

/// Denormalized lookup of distinct categories, used to build browse/filter menus
/// without scanning the whole listing table. Populated by scripts/import-listings.mjs.
/// (No FK join is needed: each listing carries its own categoryName/categorySlug,
/// which is what every read query filters on — keeping imports order-independent.)
model Category {
  slug  String @id
  name  String
  count Int    @default(0)
}

/// A buyer's offer on a listing. Money in integer cents. `status` is a plain
/// string enum: pending|accepted|countered|declined.
model Offer {
  id            String   @id @default(cuid())
  listingId     Int
  listingTitle  String
  listingImage  String?
  buyerName     String
  buyerState    String?
  amountCents   Int
  listPriceCents Int
  status        String   @default("pending") // pending|accepted|countered|declined
  counterCents  Int?
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([listingId])
  @@index([status])
}

/// A reserved/confirmed purchase moving through the delivery lifecycle. Money in
/// integer cents. `status`: reserved|scheduled|picked_up|in_transit|delivered|paid|cancelled.
model Order {
  id              String   @id @default(cuid())
  listingId       Int
  listingTitle    String
  listingImage    String?
  buyerName       String
  priceCents      Int
  depositCents    Int      @default(100)
  balanceCents    Int
  deliveryFeeCents Int     @default(0)
  status          String   @default("reserved") // reserved|scheduled|picked_up|in_transit|delivered|paid|cancelled
  pickupCity      String?
  deliverCity     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

/// Append-only timeline of order lifecycle events (label + timestamp).
model OrderEvent {
  id      String   @id @default(cuid())
  orderId String
  label   String
  at      DateTime @default(now())

  @@index([orderId])
}

/// A work-in-progress seller listing before publish. Free-form JSON captures the
/// dynamic category question answers and photo set. Money in integer cents.
model ListingDraft {
  id            String   @id @default(cuid())
  categorySlug  String?
  categoryName  String?
  title         String?
  priceCents    Int?
  floorCents    Int?
  originalCents Int?
  condition     String?
  answers       Json?
  photos        Json?
  pickupAddress String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
