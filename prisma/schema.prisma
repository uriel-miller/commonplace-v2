// Prisma schema — Postgres data foundation for the Commonplace marketplace.
// Mirrors the `Listing` domain type (src/lib/listing.ts) plus the raw WooCommerce
// fields we import. The client is consumed by src/lib/db.ts and src/lib/dataSource.ts.
//
// Prisma 7 note: the datasource `url` is NO LONGER allowed in the schema (P1012).
// The connection string lives in prisma.config.ts (`datasource.url` <- DATABASE_URL)
// for Migrate/CLI, and is passed to `new PrismaClient({ accelerateUrl })` at runtime.
// See scripts/README-import.md.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  // Emit explicit ".ts" import specifiers inside the generated (—@ts-nocheck) client
  // so BOTH bundlers (Next/Turbopack) AND plain Node ESM — used by
  // scripts/import-listings.mjs via native TypeScript type-stripping — can resolve it.
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

/// A sellable marketplace listing, normalized 1:1 from the WooCommerce Store API.
/// `id` is the WooCommerce product id (stable) so imports upsert idempotently.
model Listing {
  id           Int      @id
  slug         String   @unique
  title        String
  priceCents   Int
  /// Original/retail price when on sale, else null.
  retailCents  Int?
  savingsPct   Int?
  categoryName String
  categorySlug String
  /// Parsed "City, ST" when present in the title.
  location     String?
  condition    String?
  /// string[] of image URLs.
  images       Json
  /// string[] of plain-text description paragraphs.
  description  Json
  sku          String
  dimensions   String?
  weight       String?
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  permalink    String
  updatedAt    DateTime @updatedAt

  @@index([categorySlug])
  @@index([priceCents])
  @@index([rating])
  @@index([updatedAt])
}

/// Product-analytics event stream (screens, clicks, listing views, funnel steps).
/// High-write, append-only. Written by /api/track (batched, fail-soft) and read
/// by the admin analytics dashboard. Keep this lean + heavily indexed.
model AnalyticsEvent {
  id         String   @id @default(cuid())
  /// Stable per-browser id (localStorage) — the "user" across sessions.
  anonId     String
  /// Per-tab/session id (resets after 30m idle).
  sessionId  String
  /// Signed-in phone/user id when known, else null.
  userId     String?
  /// Event category: view | click | funnel | scroll | search | error | custom.
  type       String
  /// Event name, e.g. "screen:product", "click:add_to_cart", "sell:step".
  name       String
  /// Current app "screen"/view (product, browse, sell, checkout, …).
  screen     String?
  /// URL path at the time of the event.
  path       String?
  /// Listing id when the event concerns a specific listing.
  listingId  Int?
  /// Category slug in context, when relevant.
  categorySlug String?
  /// Free-form structured payload (coords, element, funnel step, value, …).
  props      Json?
  /// Viewport + referrer + device hints captured once per session.
  referrer   String?
  viewportW  Int?
  viewportH  Int?
  ts         DateTime @default(now())

  @@index([anonId])
  @@index([sessionId])
  @@index([type])
  @@index([name])
  @@index([screen])
  @@index([listingId])
  @@index([ts])
}

/// Blog / articles (buying guides, how-tos) ported 1:1 from the live WordPress
/// REST API by scripts/import-blog.mjs. Read fail-soft by src/lib/blog.ts.
model BlogPost {
  id          Int      @id
  slug        String   @unique
  title       String
  /// Short plain-text summary for cards / meta description.
  excerpt     String
  /// Full sanitized post HTML.
  contentHtml String
  /// Featured image URL, when present.
  coverImage  String?
  /// Comma-joined category names (for a light topic label).
  category    String?
  publishedAt DateTime
  updatedAt   DateTime @default(now())

  @@index([publishedAt])
}

/// Denormalized lookup of distinct categories, used to build browse/filter menus
/// without scanning the whole listing table. Populated by scripts/import-listings.mjs.
/// (No FK join is needed: each listing carries its own categoryName/categorySlug,
/// which is what every read query filters on — keeping imports order-independent.)
model Category {
  slug  String @id
  name  String
  count Int    @default(0)
}

/// A buyer's offer on a listing. Money in integer cents. `status` is a plain
/// string enum: pending|accepted|countered|declined.
model Offer {
  id            String   @id @default(cuid())
  listingId     Int
  listingTitle  String
  listingImage  String?
  buyerName     String
  buyerState    String?
  amountCents   Int
  listPriceCents Int
  status        String   @default("pending") // pending|accepted|countered|declined
  counterCents  Int?
  message       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([listingId])
  @@index([status])
}

/// A reserved/confirmed purchase moving through the delivery lifecycle. Money in
/// integer cents. `status`: reserved|scheduled|picked_up|in_transit|delivered|paid|cancelled.
model Order {
  id              String   @id @default(cuid())
  listingId       Int
  listingTitle    String
  listingImage    String?
  buyerName       String
  priceCents      Int
  depositCents    Int      @default(100)
  balanceCents    Int
  deliveryFeeCents Int     @default(0)
  status          String   @default("reserved") // reserved|scheduled|picked_up|in_transit|delivered|paid|cancelled
  pickupCity      String?
  deliverCity     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

/// Append-only timeline of order lifecycle events (label + timestamp).
model OrderEvent {
  id      String   @id @default(cuid())
  orderId String
  label   String
  at      DateTime @default(now())

  @@index([orderId])
}

/// A work-in-progress seller listing before publish. Free-form JSON captures the
/// dynamic category question answers and photo set. Money in integer cents.
model ListingDraft {
  id            String   @id @default(cuid())
  categorySlug  String?
  categoryName  String?
  title         String?
  priceCents    Int?
  floorCents    Int?
  originalCents Int?
  condition     String?
  answers       Json?
  photos        Json?
  pickupAddress String?
  status        String   @default("draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/**
 * A real marketplace account. Created/looked-up on the first successful OTP
 * verification, keyed by phone (the login identifier). Email/name fill in later.
 */
model User {
  id        String    @id @default(cuid())
  phone     String    @unique          // E.164, the login identifier
  email     String?
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]

  @@index([email])
}

/** A logged-in session. `token` lives in an httpOnly cookie; rows expire. */
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

/**
 * A pending one-time login code. The plaintext code is NEVER stored — only a
 * salted hash. Rows are single-use, rate-limited, and expire in minutes.
 */
model OtpCode {
  id        String   @id @default(cuid())
  phone     String                    // E.164 the code was sent to
  codeHash  String                    // sha256(code + phone + secret)
  attempts  Int      @default(0)      // wrong-guess counter (locks at 5)
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([phone])
  @@index([expiresAt])
}

/**
 * Short-lived handoff so a seller can add listing photos from their phone.
 * The desktop create-listing form opens a session (code shown + optionally
 * texted), the phone opens /add-photos/{code} and uploads, and the desktop
 * polls by `token` to pull the photos back into the form.
 */
model PhotoSession {
  id        String   @id @default(cuid())
  code      String   @unique          // short human/URL code, e.g. "K7QF2P"
  token     String   @unique          // desktop poll secret (never in the SMS link)
  phone     String?                   // E.164-ish number the link was texted to
  photos    Json?                     // string[] of data:image/... URLs
  status    String   @default("open") // open | closed
  smsSent   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  @@index([expiresAt])
}
